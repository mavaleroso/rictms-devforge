{
    "key": "laravel-inertia-react-template",
    "name": "Laravel + Inertia + React Starter Kit",
    "description": "The full Laravel React starter kit installed under resources/challenge-templates. Interns edit real project files; Simple Browser loads the running app preview URL.",
    "layout": "project",
    "preview_url": "http://127.0.0.1:8001",
    "preview_path": "/",
    "stack": ["Laravel 12", "Inertia.js", "React", "Vite", "Tailwind", "Ziggy"],
    "entry_page": "resources/js/pages/welcome.tsx",
    "include": ["**/*"],
    "exclude_prefixes": [
        "vendor",
        "node_modules",
        "storage/framework",
        "storage/logs",
        "storage/app",
        "bootstrap/cache",
        "public/build",
        "public/hot",
        ".git",
        ".cursor",
        ".github"
    ],
    "exclude_names": [
        ".env",
        "manifest.json",
        "composer.lock",
        "package-lock.json",
        ".DS_Store",
        "Thumbs.db",
        "database.sqlite",
        "database.sqlite-journal"
    ],
    "max_file_bytes": 512000,
    "readonly_prefixes": [
        "bootstrap/",
        "config/",
        "database/factories/",
        "public/",
        "resources/js/components/ui/",
        "resources/js/app.tsx",
        "resources/js/ssr.jsx",
        "resources/views/",
        "app/Http/Middleware/",
        "app/Providers/",
        "app/Models/",
        "tests/",
        "artisan",
        "composer.json",
        "package.json",
        "phpunit.xml",
        "vite.config.js",
        "tsconfig.json",
        "eslint.config.js",
        "components.json",
        "boost.json"
    ]
}
